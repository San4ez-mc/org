// Жива Орг.Платформа — Prisma-схема (Фаза 1, Sheets-first)
// pgvector: колонка embedding має тип vector(768) під Vertex text-embedding-004.
// Схожість рахуємо raw-SQL (Prisma не типізує Unsupported-колонки).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ── Перелічення ───────────────────────────────────────────
enum OrgUnitType {
  DIVISION // Відділення (×7)
  DEPARTMENT // Відділ
  SECTION // Секція
  POST // Посада
}

// #217 Життєвий статус одиниці (візуально відрізняється від PAEI-кольору)
enum OrgUnitStatus {
  CURRENT // поточна
  PLANNED // запланована
  TESTING // на випробуванні
  DEPRECATED // виводиться
}

enum MemberRole {
  OWNER // власник / керівник компанії — доступ по всій компанії
  HEAD // керівник відділення/відділу — доступ у межах свого відділу
  EMPLOYEE // співробітник — свої інструкції
}

enum MemberStatus {
  EMPLOYED // працює
  DISMISSED // звільнений
}

enum InstructionStatus {
  DRAFT
  ACTIVE
}

enum ProposalType {
  INSTRUCTION_EDIT
  NEW_DOC
  STRUCTURE_CHANGE
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Компанія (тенант) ─────────────────────────────────────
model Company {
  id                String   @id @default(uuid())
  name              String
  abbr              String? // скорочення-префікс (напр. "LB")
  driveRootFolderId String? // корінь папок компанії на Drive клієнта
  orgSheetId        String? // Google Sheet з оргсхемою
  googleAccountId   String? // прив'язаний OAuth Google-акаунт (для Drive/Sheets/Docs)

  // #213 Стратегічний шар
  mission      String? // мета компанії (навіщо існує)
  companyCkp   String? // ЦКП компанії
  idealPicture String? // ідеальна картина
  adizesStage  String? // #207 етап життєвого циклу за Адізесом

  // #219 Кілька підрозділів (материнська / дочірні структури)
  parentCompanyId String?
  parentCompany   Company?  @relation("CompanyTree", fields: [parentCompanyId], references: [id])
  subCompanies    Company[] @relation("CompanyTree")

  // Слоти під Фазу 3 (білінг) — поки не використовуються
  subscriptionPlan   String?
  subscriptionStatus String?
  trialEndsAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgUnits     OrgUnit[]
  members      Member[]
  botLinks     BotLink[]
  processes    Process[]
  instructions Instruction[]
  driveFolders DriveFolder[]
  proposals    Proposal[]
  embeddings   InstructionEmbedding[]
  changes      ChangeLog[]
  statistics   Statistic[]
  owners       Owner[]
}

// #215 Власники та інвестори з долями
enum OwnerKind {
  OWNER
  INVESTOR
}

model Owner {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  kind      OwnerKind @default(OWNER)
  sharePct  Float     @default(0) // частка у %
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
}

// ── Оргсхема (джерело зв'язків; Google Sheet — дзеркало) ───
model OrgUnit {
  id        String      @id @default(uuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    OrgUnit?    @relation("OrgUnitTree", fields: [parentId], references: [id])
  children  OrgUnit[]   @relation("OrgUnitTree")
  type      OrgUnitType
  name      String
  ckp       String? // Цінний Кінцевий Продукт
  boardNo   Int? // номер на борду (відділення 1..7 / відділ 1..21)
  orderNo   Int? // порядок серед сиблінгів

  // Поля посади (type = POST)
  holderName      String?
  reportsToUnitId String?
  reportsTo       OrgUnit?  @relation("PostReports", fields: [reportsToUnitId], references: [id])
  reportsFrom     OrgUnit[] @relation("PostReports")
  isVacant        Boolean   @default(false)
  unitStatus      OrgUnitStatus @default(CURRENT) // #217
  salary          Float?    // #198 місячна вартість посади (для ФОП/планування штату)

  memberPosts  MemberPost[]
  instructions Instruction[]
  ownedProcess Process[]     @relation("ProcessOwner")
  driveFolder  DriveFolder?
  statistics   Statistic[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([parentId])
  @@index([companyId, type])
}

// ── Статистики по ЦКП (адмін-технологія: вимірюваний показник одиниці + тренд) ──
model Statistic {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orgUnitId String
  orgUnit   OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  name      String // що вимірюємо (напр. "Дохід", "К-ть закритих угод")
  unit      String? // одиниця виміру: грн, шт, %, ...
  higherIsBetter Boolean @default(true) // напрямок «добре» (вгору чи вниз)
  points    Json     @default("[]") // [{ date: "2026-07-01", value: 123 }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([orgUnitId])
}

// ── Працівник (людина; може обіймати кілька посад) ─────────
model Member {
  id               String     @id @default(uuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String?
  telegramUserId   String?
  telegramUsername String?
  photoUrl         String?
  email            String?
  birthDate        DateTime?
  role             MemberRole @default(EMPLOYEE)
  accessToken      String?    @unique // особисте посилання входу до порталу працівника

  // Життєвий цикл працівника (#211)
  hireDate         DateTime?    // дата прийому
  status           MemberStatus @default(EMPLOYED)
  dismissedAt      DateTime?    // дата звільнення

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts    MemberPost[]
  botLinks BotLink[]

  @@unique([companyId, telegramUserId])
  @@index([companyId])
}

// ── Призначення працівника на посаду (багато-до-багатьох) ──
model MemberPost {
  id         String  @id @default(uuid())
  memberId   String
  member     Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  postUnitId String
  postUnit   OrgUnit @relation(fields: [postUnitId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  removedAt DateTime? // #211 soft-delete для історії посад (null = чинне призначення)

  @@unique([memberId, postUnitId])
  @@index([postUnitId])
}

// ── Deep-link коди для спільного бота платформи ────────────
model BotLink {
  code      String     @id
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberId  String?
  member    Member?    @relation(fields: [memberId], references: [id])
  role      MemberRole @default(EMPLOYEE)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  @@index([companyId])
}

// ── Бізнес-процеси ────────────────────────────────────────
model Process {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  ownerUnitId String?
  ownerUnit   OrgUnit? @relation("ProcessOwner", fields: [ownerUnitId], references: [id])
  steps       Json? // впорядковані кроки процесу (лінійний підсумок)
  diagram     String? // Mermaid-діаграма swimlane (лейни = відповідальні)
  graph       Json? // візуальна схема: { nodes: [...], edges: [...] } (React Flow, з гілками-рішеннями)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructions Instruction[]

  @@index([companyId])
}

// ── Посадові інструкції (тіло — Google Doc на Drive) ───────
model Instruction {
  id         String            @id @default(uuid())
  companyId  String
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postUnitId String?
  postUnit   OrgUnit?          @relation(fields: [postUnitId], references: [id])
  processId  String?
  process    Process?          @relation(fields: [processId], references: [id])
  title      String
  driveDocId String? // Google Doc з текстом інструкції
  folderPath String? // шлях теки на Drive
  status     InstructionStatus @default(DRAFT)
  version    Int               @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linksFrom  InstructionLink[]      @relation("LinkSource")
  linksTo    InstructionLink[]      @relation("LinkTarget")
  embeddings InstructionEmbedding[]
  proposals  Proposal[]

  @@index([companyId])
  @@index([postUnitId])
}

// ── Граф залежностей між інструкціями ─────────────────────
model InstructionLink {
  id                   String      @id @default(uuid())
  instructionId        String
  instruction          Instruction @relation("LinkSource", fields: [instructionId], references: [id], onDelete: Cascade)
  relatedInstructionId String
  related              Instruction @relation("LinkTarget", fields: [relatedInstructionId], references: [id], onDelete: Cascade)
  relationType         String? // напр. "shared_process", "reports_to", "references"
  weight               Float       @default(1)

  createdAt DateTime @default(now())

  @@unique([instructionId, relatedInstructionId])
  @@index([relatedInstructionId])
}

// ── Ембединги інструкцій (pgvector) ───────────────────────
model InstructionEmbedding {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  chunkNo       Int
  content       String
  driveDocId    String?
  // vector(768) під Vertex text-embedding-004; запити схожості — raw SQL
  embedding     Unsupported("vector(768)")?

  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([instructionId])
}

// ── Мапа тек Drive ↔ оргсхема ─────────────────────────────
model DriveFolder {
  id            String  @id @default(uuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orgUnitId     String  @unique
  orgUnit       OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  path          String
  driveFolderId String

  createdAt DateTime @default(now())

  @@index([companyId])
}

// ── Журнал змін (структура / процеси / інструкції) ────────
model ChangeLog {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entity     String // 'structure' | 'process' | 'instruction'
  action     String // create | update | delete | assign | unassign
  summary    String
  author     String? // хто зробив зміну (пізніше — memberId/роль)
  approvedBy String?
  approved   Boolean  @default(true) // поки авто; система затверджень — пізніше
  unitId     String? // #220 звʼязок зміни з орг-одиницею (для історії версій)
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([unitId])
}

// #194 Бібліотека шаблонів (процеси/інструкції/структури для клонування)
model Template {
  id        String   @id @default(uuid())
  companyId String
  kind      String // process | instruction | structure
  name      String
  industry  String?
  content   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// #197 Кадрові накази / політики (окремо від посадових інструкцій)
model Policy {
  id            String    @id @default(uuid())
  companyId     String
  kind          String    @default("policy") // order | policy
  title         String
  body          String
  effectiveDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
}

// #212 Облік навчання й тестування
model Training {
  id            String   @id @default(uuid())
  companyId     String
  title         String
  description   String?
  instructionId String? // навчання з посадової інструкції
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model TrainingResult {
  id         String    @id @default(uuid())
  trainingId String
  memberId   String
  score      Int?
  passedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([trainingId, memberId])
  @@index([memberId])
}

// #196 Рекрутинг-воронка: кандидати на вакансію
model Candidate {
  id           String   @id @default(uuid())
  companyId    String
  vacancyUnitId String? // посада-вакансія (OrgUnit)
  name         String
  contact      String?
  status       String   @default("new") // new | interview | hired | rejected
  aiScore      Int? // релевантність (0-100), заповнює агент оцінки
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// #226 Ознайомлення/підпис посадової інструкції («прочитав і приймаю»)
model InstructionAck {
  id             String   @id @default(uuid())
  instructionId  String
  memberId       String
  acknowledgedAt DateTime @default(now())

  @@unique([instructionId, memberId])
  @@index([instructionId])
}

// #192 Сповіщення (доставка — через спільний примітив надсилання, G5)
model OrgNotification {
  id             String   @id @default(uuid())
  companyId      String
  type           String // approval | change | vacancy
  message        String
  targetMemberId String?
  delivered      Boolean  @default(false)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([companyId, read])
}

// ── Технічні події/логи (боти, api, worker) ───────────────
model EventLog {
  id        String   @id @default(uuid())
  level     String // info | warn | error
  source    String // bot | api | worker
  message   String
  companyId String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

// ── База знань по орг.структурі (глобальна, RAG) ──────────
// Статті-методологія (Хаббард, Адізес, принципи ЦКП тощо) для обґрунтування
// рішень бота. Не привʼязана до компанії. Розмірність 768 (OpenAI/Vertex).
model KnowledgeChunk {
  id          String                      @id @default(uuid())
  source      String // назва статті / файлу
  driveFileId String?
  chunkNo     Int
  content     String
  embedding   Unsupported("vector(768)")?
  updatedAt   DateTime                    @updatedAt

  @@index([driveFileId])
}

// ── Пропозиції змін (ШІ пропонує → людина підтверджує) ─────
model Proposal {
  id                  String         @id @default(uuid())
  companyId           String
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type                ProposalType
  targetInstructionId String?
  targetInstruction   Instruction?   @relation(fields: [targetInstructionId], references: [id])
  payload             Json // деталі зміни (діф, новий текст, класифікація тощо)
  status              ProposalStatus @default(PENDING)
  createdBy           String? // memberId ініціатора
  approvedBy          String? // memberId, хто підтвердив/відхилив

  createdAt  DateTime  @default(now())
  decidedAt  DateTime?

  @@index([companyId, status])
  @@index([targetInstructionId])
}
