# ── Платформа ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── База даних (PostgreSQL + pgvector) ────────────────────
# Розширення vector має бути доступне (CREATE EXTENSION vector).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhiva_org?schema=public"

# ── Автентифікація API (бот-воронка → платформа) ──────────
PLATFORM_API_SECRET="change-me-shared-secret"

# ── Черги (Bull / Redis) ──────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI: Claude (генерація/класифікація) ───────────────────
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5"

# ── Ембединги: Google Vertex text-embedding-004 ───────────
GCP_PROJECT_ID=""
VERTEX_EMBEDDING_LOCATION="us-central1"
VERTEX_EMBEDDING_MODEL="text-embedding-004"
EMBEDDING_DIM=768
# Тека Drive зі статтями-методологією для бази знань (RAG):
KNOWLEDGE_FOLDER_ID="1gXJqIZthuDl_H6i4mF77vLwcuH2FJe5F"
# Шлях до JSON сервіс-акаунта для Vertex (ембединги платформи):
GOOGLE_APPLICATION_CREDENTIALS=""

# Fallback-ембединги (опційно):
OPENAI_API_KEY=""

# ── Google Drive/Sheets/Docs ──────────────────────────────
# Пілот: сервіс-акаунт (папку треба поділити з client_email як Редактор).
# Продакшн (Ф2): OAuth клієнта — поля нижче.
GOOGLE_SERVICE_ACCOUNT_JSON="D:/програмування/система для воронок/боти/Google Sheets AI agent/ultra-surfer-492920-a5-cd1642cd832a.json"
# Коренева папка Drive, під якою платформа створює теки компаній:
DRIVE_ROOT_FOLDER_ID="1XTRfBtWRp_YaonmLtANyhcdKVzx7Sr0M"

# ── Google OAuth (створення файлів від імені власника — для @gmail) ──
# Створити OAuth-клієнт типу "Desktop app" у Google Cloud Console (проект ultra-surfer-492920-a5).
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4123/oauth2callback"
GOOGLE_OAUTH_TOKEN_FILE="secrets/google-oauth-token.json"

# ── Telegram (спільний бот платформи; сам бот у воронках) ─
TELEGRAM_BOT_USERNAME=""
# Токен бота для сповіщень і надсилання повідомлень (sendMessage):
TELEGRAM_BOT_TOKEN=""

# ── Сповіщення email (SMTP) ────────────────────────────────
# Якщо SMTP_HOST не задано — email-канал сповіщень просто вимкнений (тихо пропускається).
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Жива Орг.Платформа <noreply@fineko.space>"
